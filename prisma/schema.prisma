datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  
  encryptionTest String   @db.Text 
  
  vaults         Vault[]
  createdAt      DateTime @default(now())
}

model Vault {
  id        String   @id @default(cuid())
  
  title     String
  titleIv   String   
  
  content   String
  contentIv String   
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}
